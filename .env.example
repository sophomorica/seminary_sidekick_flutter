# Client build-time values (passed via --dart-define / --dart-define-from-file)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxx
REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxxxxxx

# Server-side ONLY — do NOT ship in the app. The Grok/xAI key now lives in the
# sidekick-proxy Supabase Edge Function, set with:
#   supabase secrets set XAI_API_KEY=xai-...
# (Kept here for reference; it is no longer a client --dart-define.)
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
